* text=auto

# Source and documentation files are stored with LF line endings.
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.lock text eol=lf
*.md text eol=lf
*.php text eol=lf
*.sql text eol=lf
*.svg text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
.env* text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Windows command files are checked out with CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets must never be line-ending normalized.
*.gif binary
*.ico binary
*.jpeg binary
*.jpg binary
*.pdf binary
*.png binary
*.webp binary
